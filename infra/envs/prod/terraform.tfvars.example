# Copy this file to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit it.

project_id    = "CLIENT_GCP_PROJECT_ID"
region        = "asia-southeast2"
github_owner  = "CLIENT_GITLAB_GROUP_OR_USER"
github_repo   = "CLIENT_GITLAB_REPO_NAME"
alert_email   = "CLIENT_ALERT_EMAIL"
registry_repo = "tring-service"
